# Dependencies
node_modules/

# User configs (may contain credentials)
config/*.js
!config/example.js

# User scripts (contain project-specific workflows)
scripts/*
!scripts/example.sh

# User templates and examples
templates/*.html
!templates/example.html
examples/*.md
!examples/newsletter.md

# Output files
*.html

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Environment variables
.env
.env.*

# Claude Code
.claude/

# OS files
.DS_Store
Thumbs.db
